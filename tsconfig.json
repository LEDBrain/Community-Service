{
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "target": "ESNext",
        "noImplicitAny": true,
        "module": "ESNext",
        "outDir": "./dist",
        "lib": ["esnext"],
        "resolveJsonModule": true,
        "paths": {
            "@prisma-client": ["./prisma/generated/prisma-client"]
        },
        "moduleResolution": "Bundler",
        "isolatedModules": true,
        "verbatimModuleSyntax": true
    },
    "include": ["src/**/*.ts", "src/**/.*.ts"],
    "exclude": ["node_modules"]
}
